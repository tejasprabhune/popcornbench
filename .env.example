# LLM provider keys. ensemble's auto backend picks the first one set.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_AI_API_KEY=
SGLANG_API_KEY=

# popcorn_world tuning. Set per shell, or in scenarios via os.environ.
POPCORN_BACKEND=cuda
POPCORN_PRECISION=fp32
POPCORN_DEVICE_INDEX=0
POPCORN_GPU_ARCH=Hopper
POPCORN_NUM_CORRECT_TRIALS=5
POPCORN_NUM_PERF_TRIALS=100
POPCORN_TIMING_METHOD=cuda_event
POPCORN_BUILD_DIR=
POPCORN_HELD_OUT_SEED=
POPCORN_VERBOSE=false

# Per-scenario overrides used by scenarios/single_problem.py and
# scenarios/judge_review.py.
POPCORN_LEVEL=1
POPCORN_PROBLEM_ID=19
POPCORN_DATASET_SRC=huggingface
POPCORN_AGENT_MODEL=claude-sonnet-4-5
POPCORN_REVIEWER_MODEL=claude-sonnet-4-5
POPCORN_PERSONA=methodical_engineer
POPCORN_AUTHOR_PERSONA=speed_obsessed
POPCORN_MAX_TURNS=20
POPCORN_GPU_BUDGET=600
POPCORN_TOOLS=
